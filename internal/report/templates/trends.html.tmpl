<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<title>lumos trends</title>
<style>
  body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
         margin: 24px; color: #222; background: #fff; max-width: 1100px; }
  h1 { margin: 0 0 4px; font-size: 22px; }
  .meta { color: #666; font-size: 12px; margin-bottom: 24px; }
  .series { border: 1px solid #e6e6e6; border-radius: 6px; padding: 16px 18px;
            margin-bottom: 18px; background: #fff; }
  .series h2 { margin: 0 0 2px; font-size: 16px; }
  .series .sub { color: #777; font-size: 12px; margin-bottom: 12px; }
  table { border-collapse: collapse; width: 100%; }
  th, td { text-align: left; padding: 6px 10px; font-size: 13px;
           border-bottom: 1px solid #f0f0f0; vertical-align: middle; }
  th { background: #fafafa; font-weight: 600; color: #555; }
  td.metric { font-family: ui-monospace, "SF Mono", Menlo, monospace; }
  td.num   { font-variant-numeric: tabular-nums; text-align: right; }
  td.spark { width: 210px; }
  .delta { font-weight: 600; font-variant-numeric: tabular-nums; }
  .verdict { font-size: 11px; text-transform: uppercase; letter-spacing: 0.04em; }
  .empty { color: #999; font-style: italic; }
</style>
</head>
<body>

<h1>lumos · trends</h1>
<div class="meta">
  generated {{.GeneratedAt}} · {{.Tool}} {{.Version}} · {{.TotalRuns}} run(s) across {{len .Roots}} root(s)
  {{range .Roots}}<br><code>{{.}}</code>{{end}}
</div>

{{if not .Series}}
<p class="empty">No measured runs found. (Warmup-only runs are excluded.)</p>
{{end}}

{{range .Series}}
<section class="series">
  <h2>{{.Scenario}}</h2>
  <div class="sub">{{.Platform}} · {{.DeviceID}} · {{.Runs}} run(s)</div>
  <table>
    <thead>
      <tr>
        <th>metric</th>
        <th class="num">first</th>
        <th class="num">last</th>
        <th class="num">min</th>
        <th class="num">max</th>
        <th class="num">Δ</th>
        <th>verdict</th>
        <th>trend</th>
      </tr>
    </thead>
    <tbody>
      {{range .Metrics}}
      <tr>
        <td class="metric">{{.Name}}{{if .UnitLabel}} <span style="color:#aaa">({{.UnitLabel}})</span>{{end}}</td>
        <td class="num">{{fmt2 .First}}</td>
        <td class="num">{{fmt2 .Last}}</td>
        <td class="num">{{fmt2 .Min}}</td>
        <td class="num">{{fmt2 .Max}}</td>
        <td class="num delta" style="color:{{.Color}}">{{fmtPc .DeltaPct}}</td>
        <td class="verdict" style="color:{{.Color}}">{{.Verdict}}</td>
        <td class="spark">{{.SparkSVG}}</td>
      </tr>
      {{end}}
    </tbody>
  </table>
</section>
{{end}}

</body>
</html>
