<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>Lumos report</title>
<style>
  :root {
    --bg:        #0b0d10;
    --bg-elev:   #15181d;
    --bg-card:   #1b1f25;
    --border:    #262b33;
    --border-2:  #323844;
    --text:      #e6e8ec;
    --text-dim:  #9aa3af;
    --text-mute: #6b7280;
    --accent:    #22d3ee;
    --accent-2:  #818cf8;
    --good:      #34d399;
    --warn:      #fbbf24;
    --bad:       #f43f5e;
  }
  * { box-sizing: border-box; }
  html, body { margin:0; padding:0; }
  body {
    background:
      radial-gradient(900px 500px at 12% -8%, rgba(34,211,238,0.10), transparent 60%),
      radial-gradient(900px 500px at 95% 8%, rgba(129,140,248,0.10), transparent 60%),
      var(--bg);
    color: var(--text);
    font: 14px/1.55 -apple-system,BlinkMacSystemFont,'Inter','Segoe UI',Roboto,sans-serif;
    min-height: 100vh;
    padding: 32px 28px 48px;
  }
  .container { max-width: 1280px; margin: 0 auto; }
  header.hero {
    display: flex; align-items: flex-end; justify-content: space-between;
    gap: 24px; margin-bottom: 28px; padding-bottom: 20px;
    border-bottom: 1px solid var(--border);
  }
  .brand {
    display: flex; align-items: center; gap: 14px;
  }
  .brand .logo {
    width: 44px; height: 44px; border-radius: 12px;
    background: linear-gradient(135deg, var(--accent) 0%, var(--accent-2) 100%);
    box-shadow: 0 0 24px rgba(34,211,238,0.25);
    display: grid; place-items: center;
    color: #0b0d10; font-weight: 800; font-size: 22px;
  }
  .brand h1 {
    margin: 0; font-size: 22px; letter-spacing: -0.01em; font-weight: 600;
  }
  .brand .sub { color: var(--text-dim); font-size: 12px; margin-top: 2px; }
  .meta { color: var(--text-mute); font-size: 12px; text-align: right; }
  .meta .v {
    display: inline-block; padding: 2px 8px; border-radius: 999px;
    background: var(--bg-card); border: 1px solid var(--border-2);
    color: var(--text-dim); font-family: ui-monospace, Menlo, monospace;
    margin-left: 6px;
  }

  section.scenario {
    background: linear-gradient(180deg, var(--bg-elev) 0%, var(--bg-card) 100%);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 22px 24px 18px;
    margin-bottom: 22px;
    box-shadow: 0 1px 0 rgba(255,255,255,0.02) inset;
  }
  .scenario-head {
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: 16px;
  }
  .scenario-title {
    display: flex; align-items: center; gap: 10px;
  }
  .scenario-title h2 {
    margin: 0; font-size: 17px; font-weight: 600; letter-spacing: -0.005em;
  }
  .scenario-title .dot {
    width: 8px; height: 8px; border-radius: 50%;
    background: var(--accent); box-shadow: 0 0 10px var(--accent);
  }
  .scenario-meta {
    color: var(--text-dim); font-size: 12px;
    font-family: ui-monospace, Menlo, monospace;
  }

  /* KPI cards */
  .kpi-row {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 12px;
    margin-bottom: 18px;
  }
  .kpi {
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 12px 14px;
    position: relative; overflow: hidden;
  }
  .kpi-label {
    color: var(--text-mute);
    font-size: 11px; text-transform: uppercase; letter-spacing: 0.08em;
    margin-bottom: 6px;
  }
  .kpi-value {
    font-size: 24px; font-weight: 600; letter-spacing: -0.02em;
    font-variant-numeric: tabular-nums;
  }
  .kpi-unit { color: var(--text-mute); font-size: 13px; font-weight: 500; margin-left: 4px; }
  .kpi-sub  { color: var(--text-dim); font-size: 11px; margin-top: 2px;
              font-family: ui-monospace, Menlo, monospace; }
  .kpi.good .kpi-value { color: var(--good); }
  .kpi.warn .kpi-value { color: var(--warn); }
  .kpi.bad  .kpi-value { color: var(--bad); }

  /* Table of per-iteration runs */
  .runs { width: 100%; border-collapse: collapse; }
  .runs th, .runs td {
    padding: 10px 12px; text-align: right;
    border-bottom: 1px solid var(--border);
    font-variant-numeric: tabular-nums;
  }
  .runs th {
    color: var(--text-mute); font-weight: 500; font-size: 11px;
    text-transform: uppercase; letter-spacing: 0.06em;
    background: transparent;
    border-bottom-color: var(--border-2);
  }
  .runs th:first-child, .runs td:first-child { text-align: left; }
  .runs tbody tr:hover { background: rgba(255,255,255,0.02); }
  .runs td.metric.good { color: var(--good); }
  .runs td.metric.warn { color: var(--warn); }
  .runs td.metric.bad  { color: var(--bad); }
  .runs td.metric { font-weight: 500; }

  .device-cell { display: flex; align-items: center; gap: 8px; }
  .plat {
    display: inline-block; padding: 1px 7px; border-radius: 999px;
    font-size: 10px; text-transform: uppercase; letter-spacing: 0.08em;
    background: rgba(34,211,238,0.12); color: var(--accent);
    border: 1px solid rgba(34,211,238,0.25);
  }
  .plat.ios { background: rgba(129,140,248,0.12); color: var(--accent-2);
              border-color: rgba(129,140,248,0.25); }
  .iter { color: var(--text-mute); font-family: ui-monospace, Menlo, monospace; }
  .err { color: var(--bad); font-weight: 700; margin-left: 4px; }

  /* Aggregate row */
  tr.agg td {
    background: rgba(34,211,238,0.04);
    border-top: 1px solid var(--border-2);
    border-bottom: 0;
    font-weight: 600;
  }
  tr.agg td:first-child { color: var(--accent); }

  /* Per-device timeline strip — one full-width chart per metric, stacked. */
  .chart-row td { padding: 4px 12px 16px; border-bottom: 1px solid var(--border); }
  .charts {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .chart {
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 12px 16px 10px;
    width: 100%;
  }
  .chart-head {
    display: flex; justify-content: space-between; align-items: baseline;
    font-size: 11px; letter-spacing: 0.06em; text-transform: uppercase;
    color: var(--text-mute); margin-bottom: 6px;
  }
  .chart-head .name { color: var(--text-dim); font-weight: 500; }
  .chart-head .val  { color: var(--text); font-weight: 600; font-size: 13px;
                      font-family: ui-monospace, Menlo, monospace;
                      letter-spacing: 0; text-transform: none; }
  .chart svg { display: block; width: 100%; height: auto; }

  /* Per-device threads breakdown */
  .threads-row td { padding: 0 12px 16px; border-bottom: 1px solid var(--border); }
  details.threads {
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 6px 14px;
  }
  details.threads > summary {
    cursor: pointer;
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-mute);
    padding: 6px 0;
    list-style: none;
    display: flex; justify-content: space-between; align-items: center;
  }
  details.threads > summary::-webkit-details-marker { display: none; }
  details.threads > summary::before {
    content: "▸";
    margin-right: 8px;
    color: var(--text-dim);
    transition: transform 0.15s ease;
    display: inline-block;
  }
  details.threads[open] > summary::before { transform: rotate(90deg); }
  details.threads > summary .count { color: var(--text-dim); font-weight: 500; }
  .threads-chart {
    margin: 10px 0 8px;
    padding: 8px 4px 4px;
    background: var(--panel);
    border: 1px solid var(--border);
    border-radius: 8px;
  }
  .threads-chart svg { display: block; width: 100%; height: auto; }

  /* Threads dropdown picker */
  details.threads-picker {
    position: relative;
    margin: 4px 2px 10px;
    display: inline-block;
  }
  details.threads-picker > summary {
    cursor: pointer;
    list-style: none;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--panel);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 6px 12px;
    font-size: 12px;
    color: var(--text);
    user-select: none;
    transition: border-color 0.12s ease;
  }
  details.threads-picker > summary::-webkit-details-marker { display: none; }
  details.threads-picker > summary:hover { border-color: var(--border-2); }
  details.threads-picker[open] > summary { border-color: var(--accent); }
  .threads-picker-label { color: var(--text-dim); font-size: 11px;
                          letter-spacing: 0.06em; text-transform: uppercase; }
  .threads-picker-count { font-family: ui-monospace, Menlo, monospace;
                          color: var(--accent); }
  .threads-picker-caret { color: var(--text-mute); font-size: 10px;
                          transition: transform 0.15s ease; }
  details.threads-picker[open] .threads-picker-caret { transform: rotate(180deg); }
  .threads-picker-panel {
    position: absolute;
    top: calc(100% + 4px);
    left: 0;
    z-index: 20;
    min-width: 280px;
    max-width: 360px;
    max-height: 340px;
    overflow-y: auto;
    background: var(--panel);
    border: 1px solid var(--border-2);
    border-radius: 10px;
    padding: 8px;
    box-shadow: 0 8px 24px rgba(0,0,0,0.4);
  }
  .threads-picker-tools {
    display: flex; gap: 6px;
    padding: 2px 4px 8px;
    border-bottom: 1px solid var(--border);
    margin-bottom: 6px;
  }
  .threads-picker-tools button {
    background: transparent;
    color: var(--text-dim);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 3px 9px;
    font-size: 11px;
    cursor: pointer;
    font-family: inherit;
  }
  .threads-picker-tools button:hover { color: var(--text); border-color: var(--border-2); }
  ul.threads-picker-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  ul.threads-picker-list li { margin: 0; }
  ul.threads-picker-list .lg {
    display: flex; align-items: center; gap: 8px;
    padding: 5px 8px;
    border-radius: 5px;
    cursor: pointer;
    user-select: none;
    font-size: 12px;
    color: var(--text);
    font-family: ui-monospace, Menlo, monospace;
    transition: background 0.1s ease, opacity 0.1s ease;
  }
  ul.threads-picker-list .lg:hover { background: rgba(255,255,255,0.04); }
  ul.threads-picker-list .lg.off { opacity: 0.4; }
  ul.threads-picker-list .lg input { appearance: none; -webkit-appearance: none;
                                     width: 12px; height: 12px; border-radius: 3px;
                                     border: 1px solid var(--border-2);
                                     background: transparent; cursor: pointer;
                                     position: relative; margin: 0; flex: 0 0 auto; }
  ul.threads-picker-list .lg input:checked { background: var(--accent); border-color: var(--accent); }
  ul.threads-picker-list .lg input:checked::after {
    content: ""; position: absolute; left: 3px; top: 0px;
    width: 4px; height: 8px; border: solid #0b1220;
    border-width: 0 2px 2px 0; transform: rotate(45deg);
  }
  ul.threads-picker-list .sw { width: 10px; height: 10px; border-radius: 2px;
                               display: inline-block; flex: 0 0 auto; }
  ul.threads-picker-list .tn { flex: 1 1 auto; overflow: hidden;
                               text-overflow: ellipsis; white-space: nowrap; }

  footer { color: var(--text-mute); font-size: 12px; margin-top: 28px;
           text-align: center; }
  footer a { color: var(--text-dim); text-decoration: none; }

  /* Responsive */
  @media (max-width: 820px) {
    body { padding: 20px 14px 32px; }
    .runs { font-size: 12px; }
    .runs th, .runs td { padding: 8px 6px; }
  }
</style>
</head>
<body>
<div class="container">

<header class="hero">
  <div class="brand">
    <div class="logo">L</div>
    <div>
      <h1>Lumos report</h1>
      <div class="sub">Mobile performance benchmark</div>
    </div>
  </div>
  <div class="meta">
    {{.Tool}}<span class="v">{{.Version}}</span><br>
    <span>generated {{.GeneratedAt}}</span>
  </div>
</header>

{{range $scen := .Scenarios}}
<section class="scenario">
  <div class="scenario-head">
    <div class="scenario-title">
      <span class="dot"></span>
      <h2>{{.Name}}</h2>
    </div>
    <div class="scenario-meta">
      {{len .Devices}} device{{if ne (len .Devices) 1}}s{{end}}
    </div>
  </div>

  {{/* Aggregate KPI cards across all iterations + devices */}}
  <div class="kpi-row">
    {{if hasMetric .Aggregate "fps"}}
      {{$s := index .Aggregate "fps"}}
      <div class="kpi {{verdictClass "fps" $s.P90}}">
        <div class="kpi-label">FPS · p90</div>
        <div class="kpi-value">{{fmt1 $s.P90}}<span class="kpi-unit">fps</span></div>
        <div class="kpi-sub">mean {{fmt1 $s.Mean}} · min {{fmt1 $s.Min}} · max {{fmt1 $s.Max}}</div>
      </div>
    {{end}}
    {{if hasMetric .Aggregate "cpu_pct"}}
      {{$s := index .Aggregate "cpu_pct"}}
      <div class="kpi {{verdictClass "cpu_pct" $s.Mean}}">
        <div class="kpi-label">CPU · mean</div>
        <div class="kpi-value">{{fmt1 $s.Mean}}<span class="kpi-unit">%</span></div>
        <div class="kpi-sub">p90 {{fmt1 $s.P90}} · max {{fmt1 $s.Max}}</div>
      </div>
    {{end}}
    {{if hasMetric .Aggregate "ram_mb"}}
      {{$s := index .Aggregate "ram_mb"}}
      <div class="kpi {{verdictClass "ram_mb" $s.P90}}">
        <div class="kpi-label">RAM · p90</div>
        <div class="kpi-value">{{fmt0 $s.P90}}<span class="kpi-unit">MB</span></div>
        <div class="kpi-sub">mean {{fmt1 $s.Mean}} · max {{fmt1 $s.Max}}</div>
      </div>
    {{end}}
    {{if hasMetric .Aggregate "jank_pct"}}
      {{$s := index .Aggregate "jank_pct"}}
      <div class="kpi {{verdictClass "jank_pct" $s.Mean}}">
        <div class="kpi-label">Jank · mean</div>
        <div class="kpi-value">{{fmt2 $s.Mean}}<span class="kpi-unit">%</span></div>
        <div class="kpi-sub">p90 {{fmt2 $s.P90}}</div>
      </div>
    {{end}}
    {{if hasMetric .Aggregate "battery_pct"}}
      {{$s := index .Aggregate "battery_pct"}}
      <div class="kpi">
        <div class="kpi-label">Battery · last</div>
        <div class="kpi-value">{{fmt0 $s.Min}}<span class="kpi-unit">%</span></div>
        <div class="kpi-sub">temp {{fmt1 (index .Aggregate "battery_temp_c").Mean}} °C</div>
      </div>
    {{end}}
  </div>

  <table class="runs">
    <thead>
      <tr>
        <th>device</th>
        <th>runs</th>
        <th>FPS mean</th>
        <th>FPS p90</th>
        <th>CPU mean</th>
        <th>CPU p90</th>
        <th>RAM mean</th>
        <th>RAM p90</th>
        <th>jank mean</th>
        <th>marks</th>
      </tr>
    </thead>
    <tbody>
      {{range .Devices}}
      <tr>
        <td>
          <div class="device-cell">
            <span class="plat {{.Platform}}">{{.Platform}}</span>
            <span>{{.DeviceID}}</span>
            {{if .Error}}<span class="err" title="{{.Error}}">⚠</span>{{end}}
          </div>
        </td>
        <td class="iter">{{.Iterations}}×</td>
        <td class="metric {{verdictClass "fps"      (index .Summary "fps").Mean}}">{{fmt1 (index .Summary "fps").Mean}}</td>
        <td class="metric {{verdictClass "fps"      (index .Summary "fps").P90 }}">{{fmt1 (index .Summary "fps").P90}}</td>
        <td class="metric {{verdictClass "cpu_pct"  (index .Summary "cpu_pct").Mean}}">{{fmt1 (index .Summary "cpu_pct").Mean}}</td>
        <td class="metric {{verdictClass "cpu_pct"  (index .Summary "cpu_pct").P90 }}">{{fmt1 (index .Summary "cpu_pct").P90}}</td>
        <td class="metric {{verdictClass "ram_mb"   (index .Summary "ram_mb").Mean}}">{{fmt0 (index .Summary "ram_mb").Mean}}</td>
        <td class="metric {{verdictClass "ram_mb"   (index .Summary "ram_mb").P90 }}">{{fmt0 (index .Summary "ram_mb").P90}}</td>
        <td class="metric {{verdictClass "jank_pct" (index .Summary "jank_pct").Mean}}">{{fmt2 (index .Summary "jank_pct").Mean}}</td>
        <td class="iter">{{.Markers}}</td>
      </tr>
      <tr class="chart-row">
        <td colspan="10">
          <div class="charts">
            <div class="chart">
              <div class="chart-head"><span class="name">FPS</span><span class="val">{{fmt1 (index .Summary "fps").Mean}}</span></div>
              {{svgLine (index .Series "fps") (metricColor "fps")}}
            </div>
            <div class="chart">
              <div class="chart-head"><span class="name">CPU %</span><span class="val">{{fmt1 (index .Summary "cpu_pct").Mean}}</span></div>
              {{svgLine (index .Series "cpu_pct") (metricColor "cpu_pct")}}
            </div>
            <div class="chart">
              <div class="chart-head"><span class="name">RAM MB</span><span class="val">{{fmt0 (index .Summary "ram_mb").Mean}}</span></div>
              {{svgLine (index .Series "ram_mb") (metricColor "ram_mb")}}
            </div>
            <div class="chart">
              <div class="chart-head"><span class="name">jank %</span><span class="val">{{fmt2 (index .Summary "jank_pct").Mean}}</span></div>
              {{svgLine (index .Series "jank_pct") (metricColor "jank_pct")}}
            </div>
          </div>
        </td>
      </tr>
      {{if .Threads}}
      <tr class="threads-row">
        <td colspan="10">
          <details class="threads" open>
            <summary>
              <span>Threads <span class="count">({{len .Threads}} groups)</span></span>
              <span class="count">stacked CPU% over time · top {{len .ThreadSeries}}</span>
            </summary>
            {{if .ThreadSeries}}
            {{svgThreads .ThreadSeries (printf "lumos-threads-%s-%s" $scen.Name .DeviceID)}}
            {{end}}
          </details>
        </td>
      </tr>
      {{end}}
      {{end}}
      {{if gt (len .Devices) 1}}
      <tr class="agg">
        <td colspan="2">aggregate</td>
        <td class="metric {{verdictClass "fps"      (index .Aggregate "fps").Mean}}">{{fmt1 (index .Aggregate "fps").Mean}}</td>
        <td class="metric {{verdictClass "fps"      (index .Aggregate "fps").P90 }}">{{fmt1 (index .Aggregate "fps").P90}}</td>
        <td class="metric {{verdictClass "cpu_pct"  (index .Aggregate "cpu_pct").Mean}}">{{fmt1 (index .Aggregate "cpu_pct").Mean}}</td>
        <td class="metric {{verdictClass "cpu_pct"  (index .Aggregate "cpu_pct").P90 }}">{{fmt1 (index .Aggregate "cpu_pct").P90}}</td>
        <td class="metric {{verdictClass "ram_mb"   (index .Aggregate "ram_mb").Mean}}">{{fmt0 (index .Aggregate "ram_mb").Mean}}</td>
        <td class="metric {{verdictClass "ram_mb"   (index .Aggregate "ram_mb").P90 }}">{{fmt0 (index .Aggregate "ram_mb").P90}}</td>
        <td class="metric {{verdictClass "jank_pct" (index .Aggregate "jank_pct").Mean}}">{{fmt2 (index .Aggregate "jank_pct").Mean}}</td>
        <td></td>
      </tr>
      {{end}}
    </tbody>
  </table>
</section>
{{end}}

<footer>
  Lumos · schema v1 · per-device + aggregate views · interactive threads chart (JS); everything else works offline.
</footer>
</div>
<script>
// Interactive threads chart: rebuild stacked polygons whenever the dropdown
// picker selection changes. All geometry constants must match svgStackedThreads.
(function () {
  const MARGIN_L = 40, MARGIN_R = 8, MARGIN_T = 8, MARGIN_B = 18;
  const W = 800, H = 200;
  const PLOT_W = W - MARGIN_L - MARGIN_R;
  const PLOT_H = H - MARGIN_T - MARGIN_B;

  // Locate the dropdown picker that belongs to a given chart container.
  // The picker is the next-sibling .threads-picker within the same parent.
  function pickerFor(container) {
    let n = container.nextElementSibling;
    while (n && !n.classList.contains("threads-picker")) n = n.nextElementSibling;
    return n;
  }

  function rebuild(container) {
    const svg = container.querySelector("svg");
    const dataEl = container.querySelector("script.lumos-thread-data");
    if (!svg || !dataEl) return;
    let series;
    try { series = JSON.parse(dataEl.textContent); } catch (e) { return; }
    const n = series[0] && series[0].v ? series[0].v.length : 0;
    if (n < 2) return;

    const picker = pickerFor(container);
    const enabled = new Array(series.length).fill(true);
    let onCount = series.length;
    if (picker) {
      onCount = 0;
      picker.querySelectorAll('input[type="checkbox"]').forEach(cb => {
        const idx = parseInt(cb.dataset.thread, 10);
        if (!isNaN(idx)) {
          enabled[idx] = cb.checked;
          if (cb.checked) onCount++;
        }
        const label = cb.closest(".lg");
        if (label) label.classList.toggle("off", !cb.checked);
      });
      // Update the count badge "<on> / <total>".
      const badge = picker.querySelector(".threads-picker-count");
      if (badge) badge.textContent = onCount + " / " + series.length;
    }

    // Recompute peak across enabled series (max of any single sample,
    // not summed — lines are overlaid, not stacked).
    let peak = 0;
    for (let k = 0; k < series.length; k++) {
      if (!enabled[k]) continue;
      for (let i = 0; i < n; i++) {
        const v = series[k].v[i] || 0;
        if (v > peak) peak = v;
      }
    }
    if (peak <= 0) peak = 1;
    const ymax = niceCeil(peak);

    const xAt = i => MARGIN_L + PLOT_W * (i / (n - 1));
    const yAt = v => MARGIN_T + PLOT_H - PLOT_H * (v / ymax);

    // Update axis labels in place.
    const yTicks = svg.querySelectorAll("g.axes text.ytick");
    yTicks.forEach((el, t) => { el.textContent = formatTick(ymax * t / (yTicks.length - 1)); });

    // Rebuild lines (one polyline per series).
    const lines = svg.querySelectorAll("g.bands polyline");
    for (let k = 0; k < series.length; k++) {
      const poly = lines[k];
      if (!poly) continue;
      if (!enabled[k]) { poly.style.display = "none"; continue; }
      poly.style.display = "";
      const parts = [];
      for (let i = 0; i < n; i++) {
        parts.push(xAt(i).toFixed(1) + "," + yAt(series[k].v[i] || 0).toFixed(1));
      }
      poly.setAttribute("points", parts.join(" "));
    }
  }

  function niceCeil(v) {
    if (v <= 0) return 1;
    let mag = 1;
    while (v / mag > 10) mag *= 10;
    const r = v / mag;
    if (r <= 1) return 1 * mag;
    if (r <= 2) return 2 * mag;
    if (r <= 2.5) return 2.5 * mag;
    if (r <= 5) return 5 * mag;
    return 10 * mag;
  }
  function formatTick(v) {
    if (v === 0) return "0";
    if (v >= 100) return v.toFixed(0);
    if (v >= 10)  return v.toFixed(0);
    return v.toFixed(1);
  }

  // Wire each chart to its dropdown picker.
  document.querySelectorAll("[data-lumos-threads]").forEach(container => {
    const picker = pickerFor(container);
    if (!picker) return;
    picker.addEventListener("change", () => rebuild(container));
    picker.addEventListener("click", e => {
      const btn = e.target.closest("button[data-lumos-threads-all], button[data-lumos-threads-top]");
      if (!btn) return;
      e.preventDefault();
      const boxes = picker.querySelectorAll('input[type="checkbox"]');
      if (btn.dataset.lumosThreadsAll !== undefined) {
        const on = btn.dataset.lumosThreadsAll === "1";
        boxes.forEach(cb => { cb.checked = on; });
      } else if (btn.dataset.lumosThreadsTop !== undefined) {
        const n = parseInt(picker.dataset.defaultVisible || "3", 10);
        boxes.forEach((cb, i) => { cb.checked = i < n; });
      }
      rebuild(container);
    });
    // Close the dropdown when clicking outside.
    document.addEventListener("click", e => {
      if (picker.open && !picker.contains(e.target)) picker.open = false;
    });
    // Initial render reflects the default-checked subset baked into HTML.
    rebuild(container);
  });
})();
</script>
</body>
</html>

